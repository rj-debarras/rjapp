# ========================
# RJ Débarras Environment
# ========================

# Telegram Bot Notification
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Cloudflare D1 Database
# These are set automatically by wrangler for local dev
# For production, set via: wrangler pages secret put DB

# Contact Information (Vite Frontend)
# Use VITE_ prefix for frontend access
VITE_PHONE_NUMBER=01XXXXXXXX
VITE_WHATSAPP_NUMBER=33XXXXXXXXX
VITE_CONTACT_EMAIL=contact@rjdebarras.com
VITE_POSTAL_ADDRESS=Île-de-France

# Security (server-side only — set in Cloudflare Worker vars for production)
ADMIN_PASSWORD=change_me_to_a_strong_password
SESSION_SECRET=change_me_to_a_random_64char_hex
